# Copy to deploy/.env and fill in. The password is read only from the
# environment — it is never written to a config file or logged.
#
# Broker credentials for programmatic MT5 login (headless). Leave blank to log
# in manually via the VNC web UI instead (one-time; persists in the volume).
MT5_LOGIN=00000000
MT5_PASSWORD=
MT5_SERVER=Your-Broker-Server

# KasmVNC web-UI auth — the one-time terminal login at http://127.0.0.1:3001.
VNC_USER=mt5
VNC_PASSWORD=change-me
